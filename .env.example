# KK-Check — Beispiel-Umgebung (Server)
JWT_SECRET=generiere-mit-openssl-rand-base64-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=starkes-passwort-setzen
PORT=3000

# Reminder-E-Mails (z. B. Brevo gratis: smtp-relay.brevo.com, Port 587)
# SMTP_PASS nur hier setzen, nicht im Admin-UI
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=deine-brevo-login-email
SMTP_PASS=dein-brevo-smtp-key
SMTP_FROM=noreply@deine-domain.de
SMTP_PORT=587

# Optional: Cron für tägliche Erinnerungsmails
CRON_SECRET=beliebiges-geheimes-token
